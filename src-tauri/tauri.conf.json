{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cerberus",
  "version": "0.2.0",
  "identifier": "com.les-t.cerberus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cerberus",
        "width": 1180,
        "height": 780,
        "minWidth": 920,
        "minHeight": 620,
        "center": true,
        "decorations": false,
        "theme": "Dark"
      },
      {
        "label": "panel",
        "title": "Cerberus Panel",
        "width": 116,
        "height": 40,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false,
        "visible": false,
        "theme": "Dark"
      },
      {
        "label": "capregion",
        "title": "Cerberus Capture",
        "width": 340,
        "height": 96,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false,
        "visible": false
      },
      {
        "label": "radar",
        "title": "Cerberus Radar",
        "width": 300,
        "height": 336,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/LesTasker2023/cerberus/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFGODhBM0FBNTFCRjYyQTQKUldTa1lyOVJxcU9JcjFkNnpkMk52SXoxdDB3Q0phMUtwNDhTQzFDeUZTRlB2eTkwUWR0cTRVVUoK"
    }
  }
}
